{
  "name": "@nuucognition/prompt-loader",
  "version": "0.0.1",
  "description": "Markdown prompt loader with frontmatter metadata and simple template rendering",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "eslint": "^9.32.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
