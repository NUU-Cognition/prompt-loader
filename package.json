{
  "name": "@nuucognition/prompt-loader",
  "version": "0.0.1",
  "description": "Markdown prompt loader with frontmatter metadata and simple template rendering",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:smoke": "node ./scripts/smoke-package.mjs",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "lint": "eslint .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:release": "pnpm verify && pnpm test:smoke && npm pack --dry-run",
    "prepublishOnly": "pnpm verify:release"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.9",
    "eslint": "^9.32.0",
    "globals": "^17.4.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.8"
  }
}
